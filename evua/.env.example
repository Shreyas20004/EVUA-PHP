# Copy this file to .env and fill in your values.

# Gemini API key (required for AI-powered migration; leave blank to use mock AI)
GEMINI_API_KEY=

# Maximum PHP file upload size in megabytes
MAX_UPLOAD_SIZE_MB=50

# Max concurrent files processed by the migration pipeline
MAX_CONCURRENCY=5

# Set to true to use a mock AI processor instead of calling Gemini
USE_MOCK_AI=false

# CORS origins allowed to reach the backend (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Directory where uploaded PHP files are stored temporarily
UPLOAD_DIR=/tmp/evua_uploads

# Enable debug-level logging
DEBUG=false
