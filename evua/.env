# evua environment — local development
# Copy .env.example and fill in your values.

GEMINI_API_KEY=
MAX_UPLOAD_SIZE_MB=50
MAX_CONCURRENCY=5
USE_MOCK_AI=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false
# STORAGE_DIR defaults to backend/storage/ — uncomment to override
# STORAGE_DIR=/path/to/custom/storage
